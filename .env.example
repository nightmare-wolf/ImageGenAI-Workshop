# ── Core ───────────────────────────────────────────────────────────────────
ENV=dev                                   # dev | prod
SECRET_KEY=change-me-32-bytes-min         # JWT signing
SERVER_SECRET=change-me-hmac-flag-secret  # HMAC for per-session derived flags
JWT_TTL_MINUTES=240                       # workshop length + buffer

# ── Datastores ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://ctf:ctf@postgres:5432/ctf
REDIS_URL=redis://redis:6379/0

# ── Image generation ───────────────────────────────────────────────────────
IMAGEGEN_MODE=mock                        # mock | runpod
RUNPOD_API_KEY=                           # required when IMAGEGEN_MODE=runpod
RUNPOD_ENDPOINT_ID=
IMAGEGEN_TIMEOUT_SECONDS=30
IMAGEGEN_STEPS=4

# ── Limits / budget guardrails ──────────────────────────────────────────────
RATE_LIMIT_GENERATE_PER_MIN=30
RATE_LIMIT_SUBMIT_PER_MIN=10
MAX_CONCURRENT_GENERATES=16
UPLOAD_MAX_BYTES=4000000

# ── Observability ───────────────────────────────────────────────────────────
LOKI_URL=http://loki:3100
LOG_LEVEL=INFO

# ── Frontend ────────────────────────────────────────────────────────────────
VITE_API_BASE=/api
